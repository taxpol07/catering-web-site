# Firebase Client Configuration (from Firebase Console > Project Settings > General)
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789012
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789012:web:abcdef123456

# Admin UID — Firebase Auth user ID allowed to access admin panel
NEXT_PUBLIC_ADMIN_UID=your_admin_user_uid

# Business contact details
NEXT_PUBLIC_WHATSAPP_NUMBER=447700900000
NEXT_PUBLIC_FACEBOOK_URL=https://www.facebook.com/yourpage
NEXT_PUBLIC_BUSINESS_NAME=Premier Catering Equipment UK
NEXT_PUBLIC_BUSINESS_PHONE=+44 7700 900000
NEXT_PUBLIC_BUSINESS_EMAIL=info@premiercatering.co.uk
NEXT_PUBLIC_BUSINESS_ADDRESS=Unit 5, Industrial Estate, Manchester, M1 2AB, UK

# Production site URL (for sitemap and SEO)
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app

# Optional: For seed script only (server-side)
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
